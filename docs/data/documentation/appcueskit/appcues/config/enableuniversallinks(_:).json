{"abstract":[{"type":"text","text":"Set the universal link handling preference for the configuration."}],"kind":"symbol","metadata":{"modules":[{"name":"AppcuesKit"}],"title":"enableUniversalLinks(_:)","role":"symbol","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"enableUniversalLinks","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"}],"externalID":"s:10AppcuesKit0A0C6ConfigC20enableUniversalLinksyAEXDSbF","roleHeading":"Instance Method","symbolKind":"method"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config\/enableUniversalLinks(_:)"},"primaryContentSections":[{"kind":"declarations","declarations":[{"tokens":[{"text":"@discardableResult","kind":"attribute"},{"text":" ","kind":"text"},{"text":"@objc","kind":"attribute"},{"text":" ","kind":"text"},{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"enableUniversalLinks","kind":"identifier"},{"text":"(","kind":"text"},{"text":"_","kind":"externalParam"},{"text":" ","kind":"text"},{"text":"enabled","kind":"internalParam"},{"text":": ","kind":"text"},{"preciseIdentifier":"s:Sb","text":"Bool","kind":"typeIdentifier"},{"text":") -> ","kind":"text"},{"text":"Self","kind":"typeIdentifier"}],"platforms":["iOS","iPadOS","Mac Catalyst"],"languages":["swift"]}]},{"kind":"parameters","parameters":[{"name":"enabled","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Whether universal link handling is enabled."}]}]}]},{"kind":"content","content":[{"level":2,"type":"heading","text":"Return Value","anchor":"return-value"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"codeVoice","code":"Configuration"},{"type":"text","text":" object."}]}]},{"mentions":["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/UniversalLinking"],"kind":"mentions"},{"kind":"content","content":[{"level":2,"type":"heading","text":"Discussion","anchor":"discussion"},{"type":"paragraph","inlineContent":[{"type":"text","text":"When this property is enabled, the SDK will pass web links that are triggered by an experience back to the host"},{"type":"text","text":" "},{"type":"text","text":"application to process. The host application should implement the "},{"type":"codeVoice","code":"application(_:continue:restorationHandler:)"},{"type":"text","text":" "},{"type":"text","text":"in its "},{"type":"codeVoice","code":"ApplicationDelegate"},{"type":"text","text":" to return "},{"type":"codeVoice","code":"true"},{"type":"text","text":" if the link provided in the given "},{"type":"codeVoice","code":"NSUserActivity"},{"type":"text","text":" has been handled"},{"type":"text","text":" "},{"type":"text","text":"as a universal link inside the current application, or "},{"type":"codeVoice","code":"false"},{"type":"text","text":" if not. When a value of "},{"type":"codeVoice","code":"true"},{"type":"text","text":" is returned, this informs the SDK"},{"type":"text","text":" "},{"type":"text","text":"that no further link handling is needed. When a value of "},{"type":"codeVoice","code":"false"},{"type":"text","text":" is returned, the SDK will continue handling the link and open"},{"type":"text","text":" "},{"type":"text","text":"the web destination in the browser."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"When this property is disabled, any web links triggered by an experience will always be opened in the browser, regardless of"},{"type":"text","text":" "},{"type":"text","text":"whether it was a universal link that may have been intended to deep link to another screen in the app."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The default value for this configuration is "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]}]}],"variants":[{"paths":["\/documentation\/appcueskit\/appcues\/config\/enableuniversallinks(_:)"],"traits":[{"interfaceLanguage":"swift"}]}],"sections":[],"schemaVersion":{"major":0,"minor":3,"patch":0},"hierarchy":{"paths":[["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config"]]},"references":{"doc://com.appcues.sdk/documentation/AppcuesKit":{"kind":"symbol","url":"\/documentation\/appcueskit","role":"collection","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit","type":"topic","title":"AppcuesKit","abstract":[{"text":"Appcues iOS SDK allows you to integrate Appcues experiences into your native iOS and iPadOS apps.","type":"text"}]},"doc://com.appcues.sdk/documentation/AppcuesKit/Appcues":{"role":"symbol","url":"\/documentation\/appcueskit\/appcues","fragments":[{"text":"class","kind":"keyword"},{"text":" ","kind":"text"},{"text":"Appcues","kind":"identifier"}],"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues","abstract":[{"text":"An object that manages Appcues tracking and rendering of experience content, for your app.","type":"text"}],"navigatorTitle":[{"text":"Appcues","kind":"identifier"}],"type":"topic","title":"Appcues","kind":"symbol"},"doc://com.appcues.sdk/documentation/AppcuesKit/Appcues/Config/enableUniversalLinks(_:)":{"role":"symbol","type":"topic","kind":"symbol","abstract":[{"type":"text","text":"Set the universal link handling preference for the configuration."}],"url":"\/documentation\/appcueskit\/appcues\/config\/enableuniversallinks(_:)","fragments":[{"text":"func","kind":"keyword"},{"text":" ","kind":"text"},{"text":"enableUniversalLinks","kind":"identifier"},{"text":"(","kind":"text"},{"preciseIdentifier":"s:Sb","kind":"typeIdentifier","text":"Bool"},{"kind":"text","text":") -> "},{"kind":"typeIdentifier","text":"Self"}],"title":"enableUniversalLinks(_:)","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config\/