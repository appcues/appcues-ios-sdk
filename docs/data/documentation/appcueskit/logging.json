{"metadata":{"title":"Working with Logs","modules":[{"name":"AppcuesKit"}],"roleHeading":"Article","role":"article"},"identifier":{"url":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Logging","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/appcueskit\/logging"],"traits":[{"interfaceLanguage":"swift"}]}],"abstract":[{"type":"text","text":"Appcues for iOS can be configured to enable logging via Apple’s unified logging system, ensuring logs are accessible, performant, and private."}],"hierarchy":{"paths":[["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues"]]},"primaryContentSections":[{"content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Logging is disabled by default and no logs are generated when logging is disabled. When enabled, log are captured at levels corresponding to their importance. An error-level log may indicate why an Appcues experience failed to display. Debug-level logs contain much more granular information about the internal operation of the Appcues SDK."}]},{"type":"heading","text":"Enable Logging","anchor":"Enable-Logging","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Logging is enabled via the configuration of your "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues"},{"type":"text","text":" instance. Call "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config\/logging(_:)"},{"type":"text","text":" with a value of "},{"type":"codeVoice","code":"true"},{"type":"text","text":"."}]},{"type":"heading","text":"Viewing Logs","anchor":"Viewing-Logs","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"Once enabled, logs can be viewed several different ways:"}]},{"type":"heading","text":"Console","anchor":"Console",