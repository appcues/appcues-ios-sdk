{"hierarchy":{"paths":[["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit"]]},"identifier":{"url":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/GettingStarted","interfaceLanguage":"swift"},"variants":[{"paths":["\/documentation\/appcueskit\/gettingstarted"],"traits":[{"interfaceLanguage":"swift"}]}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"anchor":"Initializing-the-SDK","text":"Initializing the SDK"},{"inlineContent":[{"type":"text","text":"An instance of the Appcues iOS SDK ("},{"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues","isActive":true,"type":"reference"},{"type":"text","text":") should be initialized when your app launches. A lifecycle method such as "},{"code":"application(_:didFinishLaunchingWithOptions:)","type":"codeVoice"},{"type":"text","text":" would be a common location:"}],"type":"paragraph"},{"syntax":"swift","code":["func application(_ application: UIApplication, didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","  let appcuesConfig = Appcues.Config(","    accountID: <#APPCUES_ACCOUNT_ID#>,","    applicationID: <#APPCUES_APPLICATION_ID#>)","    ","  appcues = Appcues(config: appcuesConfig)","}"],"type":"codeListing"},{"inlineContent":[{"text":"The ","type":"text"},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config"},{"type":"text","text":" object has a number of properties that may optionally be set to customize the behavior of the SDK."}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"text":"Initializing the SDK requires you to provide two values, an Appcues account ID, and an Appcues mobile application ID. These values can be obtained from your ","type":"text"},{"isActive":true,"type":"reference","identifier":"https:\/\/studio.appcues.com\/settings\/account"},{"type":"text","text":"."}]},{"anchor":"Managing-Users","type":"heading","level":2,"text":"Managing Users"},{"inlineContent":[{"text":"In order to target content to the right users at the right time, you need to identify users and send Appcues data about them. A user is identified with a unique ID.","type":"text"}],"type":"paragraph"},{"items":[{"content":[{"inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/identify(userID:properties:)"}],"type":"paragraph"}]}],"type":"unorderedList"},{"inlineContent":[{"type":"text","text":"For more detail about session management and anonymous user tracking, refer to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Identifying"},{"text":".","type":"text"}],"type":"paragraph"},{"type":"heading","anchor":"Tracking-Screens-and-Events","level":2,"text":"Tracking Screens and Events"},{"inlineContent":[{"type":"text","text":"Events are the “actions” your users take in your application, which can be anything from clicking a certain button to viewing a specific screen. Once you’ve installed and initialized the Appcues iOS SDK, you can start tracking screens and events using the following methods:"}],"type":"paragraph"},{"type":"unorderedList","items":[{"content":[{"inlineContent":[{"type":"reference","isActive":true,"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/track(name:properties:)"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"isActive":true,"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/screen(title:properties:)"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more detail about tracking screens and events, refer to "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Tracking"},{"type":"text","text":"."}]},{"anchor":"Anchored-Tooltips","level":2,"text":"Anchored Tooltips","type":"heading"},{"inlineContent":[{"type":"text","text"