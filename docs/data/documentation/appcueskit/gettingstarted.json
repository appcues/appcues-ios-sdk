{"sections":[],"hierarchy":{"paths":[["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit"]]},"metadata":{"title":"Getting Started with Appcues iOS SDK","modules":[{"name":"AppcuesKit"}],"role":"article","roleHeading":"Article"},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/GettingStarted"},"schemaVersion":{"major":0,"patch":0,"minor":3},"abstract":[{"type":"text","text":"Initialize the SDK and track events."}],"seeAlsoSections":[{"identifiers":["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Identifying","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Tracking","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/URLSchemeConfiguring","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/AnchoredTooltips","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/PushNotifications","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues"],"anchor":"Core-Functionality","title":"Core Functionality","generated":true}],"primaryContentSections":[{"content":[{"type":"heading","level":2,"text":"Initializing the SDK","anchor":"Initializing-the-SDK"},{"type":"paragraph","inlineContent":[{"type":"text","text":"An instance of the Appcues iOS SDK ("},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues"},{"type":"text","text":") should be initialized when your app launches. A lifecycle method such as "},{"type":"codeVoice","code":"application(_:didFinishLaunchingWithOptions:)"},{"type":"text","text":" would be a common location:"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication, didFinishLaunchingWithOptions launchOptions: [UIApplication.LaunchOptionsKey: Any]?) -> Bool {","  let appcuesConfig = Appcues.Config(","    accountID: <#APPCUES_ACCOUNT_ID#>,","    applicationID: <#APPCUES_APPLICATION_ID#>)","    ","  appcues = Appcues(config: appcuesConfig)","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"The "},{"type":"reference","isActive":true,"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config"},{"type":"text","text":" object has a number of properties that may optionally be set to customize the behavior of the SDK."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"Initializing the SDK requires you to provide two values, an Appcues account ID, and an Appcues mobile application ID. These values can be obtained from your "},{"type":"reference","isActive":true,"identifier":"https:\/\/studio.appcues.com\/settings\/account"},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Managing Users","anchor":"Managing-Users"},{"type":"paragraph","inlineContent":[{"type":"text","text":"In order to target content to the right users at the right time, you need to identify users and send Appcues data about them. A user is identified with a unique ID."}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/identify(userID:properties:)","type":"reference","isActive":true}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more detail about session management and anonymous user tracking, refer to "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Identifying","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Tracking Screens and Events","anchor":"Tracking-Screens-and-Events"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Events are the “actions” your users take in your application, which can be anything from clicking a certain button to viewing a specific screen. Once you’ve installed and initialized the Appcues iOS SDK, you can start tracking screens and events using the following methods:"}]},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/track(name:properties:)","isActive":true}]}]},{"content":[{"type":"paragraph","inlineContent":[{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/screen(title:properties:)","isActive":true}]}]}],"type":"unorderedList"},{"type":"paragraph","inlineContent":[{"type":"text","text":"For more detail about tracking screens and events, refer to "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Tracking","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Anchored Tooltips","anchor":"Anchored-Tooltips"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Anchored tooltips use element targeting to point directly at specific views in your application. For more information about how to configure your application’s views for element targeting, refer to "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/AnchoredTooltips","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Embedded Experiences","anchor":"Embedded-Experiences"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Add "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/AppcuesFrameView","isActive":true},{"type":"text","text":" instances in your application layouts to support embedded experience content, with a non-modal presentation. For more information about how to configure your application layouts to use frame views, refer to "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/FrameConfiguring","isActive":true},{"type":"text","text":"."}]},{"type":"heading","level":2,"text":"Debugging","anchor":"Debugging"},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/URLSchemeConfiguring","isActive":true},{"type":"text","text"