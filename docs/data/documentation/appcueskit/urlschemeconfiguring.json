’s also valuable for future troubleshooting and support from Appcues via the debugger.","type":"text"}]}]},{"type":"heading","level":2,"text":"Register the Custom URL Scheme","anchor":"Register-the-Custom-URL-Scheme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Update your "},{"type":"codeVoice","code":"Info.plist"},{"type":"text","text":" to register the custom URL scheme. Replace "},{"type":"codeVoice","code":"APPCUES_APPLICATION_ID"},{"type":"text","text":" in the snippet below with your app’s Appcues Application ID. This value can be obtained from your "},{"type":"reference","identifier":"https:\/\/studio.appcues.com\/settings\/installation","isActive":true},{"type":"text","text":"."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"For example, if your Appcues Application ID is "},{"type":"codeVoice","code":"123-xyz"},{"type":"text","text":" your url scheme value would be "},{"type":"codeVoice","code":"appcues-123-xyz"},{"type":"text","text":"."}]},{"type":"codeListing","syntax":null,"code":["<key>CFBundleURLTypes<\/key>","<array>","    <dict>","        <key>CFBundleTypeRole<\/key>","        <string>Editor<\/string>","        <key>CFBundleURLName<\/key>","        <string>$(PRODUCT_BUNDLE_IDENTIFIER)<\/string>","        <key>CFBundleURLSchemes<\/key>","        <array>","            <string>appcues-APPCUES_APPLICATION_ID<\/string>","        <\/array>","    <\/dict>","<\/array>"]},{"type":"heading","level":2,"text":"Handle the Custom URL Scheme","anchor":"Handle-the-Custom-URL-Scheme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Custom URL’s should be handled with a call to "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/filterAndHandle(_:)","isActive":true},{"type":"text","text":" or "},{"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/didHandleURL(_:)","isActive":true,"type":"reference"},{"type":"text","text":". If the URL being opened is an Appcues URL, the URL will be handled."}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your app uses a Scene delegate, add the following:"}]},{"type":"codeListing","syntax":"swift","code":["func scene(_ scene: UIScene, willConnectTo session: UISceneSession, options connectionOptions: UIScene.ConnectionOptions) {","    \/\/ Handle Appcues deep links.","    let unhandledURLContexts = appcues.filterAndHandle(connectionOptions.urlContexts)","","    \/\/ Handle any links remaining in unhandledURLContexts.","}","","func scene(_ scene: UIScene, openURLContexts URLContexts: Set<UIOpenURLContext>) {","    \/\/ Handle Appcues deep links.","    let unhandledURLContexts = appcues.filterAndHandle(URLContexts)","","    \/\/ Handle any links remaining in unhandledURLContexts.","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"If your app uses only an App delegate, add the following:"}]},{"type":"codeListing","syntax":"swift","code":["func application(_ application: UIApplication, open url: URL, options: [UIApplication.OpenURLOptionsKey : Any] = [:] ) -> Bool {","    \/\/ Handle Appcues deep links.","    guard !appcues.didHandleURL(url) else { return true }","","    \/\/ Handle a non-Appcues URL.","    return false","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"A SwiftUI app can handle the custom URL scheme as part of the "},{"type":"codeVoice","code":"onOpenURL"},{"type":"text","text":" modifier associated with the "},{"type":"codeVoice","code":"Scene"},{"type":"text","text":" of your main "},{"type":"codeVoice","code":"App"},{"type":"text","text":":"}]},{"type":"codeListing","syntax":"swift","code":["var body: some Scene {","    WindowGroup {","        MyApp()","        .onOpenURL { url in","            guard !appcues.didHandleURL(url) else { return }","        }","    }","}"]},{"type":"heading","level":2,"text":"Verifying the Custom URL Scheme","anchor":"Verifying-the-Custom-URL-Scheme"},{"type":"paragraph","inlineContent":[{"type":"text","text":"The Appcues debugger allows you to easily validate that the Appcues deep link is properly configured."}]},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"text":"Launch the debugger in your app with a call to ","type":"text"},{"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/debug()","isActive":true,"type":"reference"},{"text":".","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Expand the debugger by tapping the floating button.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Tap the “Appcues Deep Link Configured” row to verify the status. If a checkmark appears, the Appcues deep link is properly configured.","type":"text"}]}]}]},{"type":"heading","level":3,"text":"Troubleshooting","anchor":"Troubleshooting"},{"type":"unorderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"code":"Error 0","type":"codeVoice"},{"text":": The Appcues debugger was unable to set up the verification test.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Error 1","type":"codeVoice"},{"text":": The ","type":"text"},{"code":"CFBundleURLSchemes","type":"codeVoice"},{"text":" value is missing. Refer to the “Register the Custom URL Scheme” section above.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Error 2","type":"codeVoice"},{"text":": The URL scheme is registered, but the Appcues SDK did not receive the link from the host app. Refer to the “Handle the Custom URL Scheme” section above.","type":"text"}]}]},{"content":[{"type":"paragraph","inlineContent":[{"code":"Error 3","type":"codeVoice"},{"text":": The Appcues SDK received the link, but the verification token value was unexpected. Testing again should resolve the issue.","type":"text"}]}]}]},{"type":"paragraph","inlineContent":[{"type":"text","text":"See "},{"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/document