{"metadata":{"modules":[{"name":"AppcuesKit"}],"title":"Configuring Handling of Universal Links","roleHeading":"Article","role":"article"},"hierarchy":{"paths":[["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit"]]},"identifier":{"url":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/UniversalLinking","interfaceLanguage":"swift"},"seeAlsoSections":[{"anchor":"Navigation","title":"Navigation","generated":true,"identifiers":["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/HandlingNavigation","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/AppcuesNavigationDelegate"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","text":"Overview","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"You must implement ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate.application(_:continue:restorationHandler:)"},{"text":" to handle your universal links. By default, the Appcues iOS SDK will call this method for every ","type":"text"},{"type":"codeVoice","code":"https"},{"text":" link it tries to open to allow your app a chance to handle it internally instead of opening the link in a browser. Optionally, you may provide an allow list of URL hosts—refer to the Domain Allow List section below.","type":"text"}]},{"name":"Note","content":[{"inlineContent":[{"type":"text","text":"If your app has opted into "},{"isActive":true,"type":"reference","identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/app_and_environment\/scenes"},{"type":"text","text":", you still must implement the "},{"type":"codeVoice","code":"UIApplicationDelegate"},{"type":"text","text":" method to handle universal links triggered from the Appcues iOS SDK."}],"type":"paragraph"}],"style":"note","type":"aside"},{"anchor":"Implementing-the-NSUserActivity-Handler","text":"Implementing the NSUserActivity Handler","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"Your implementation of ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate.application(_:continue:restorationHandler:)"},{"text":" must return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if you’ve successfully handled the link and ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" otherwise.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If needed, you can identify links coming from the Appcues iOS SDK by a ","type":"text"},{"type":"codeVoice","code":"referrer"},{"text":" property in the ","type":"text"},{"type":"codeVoice","code":"NSUserActivity.userInfo"},{"text":" dictionary.","type":"text"}]},{"syntax":"swift","code":["\/\/ AppDelegate.swift","","func application(_ application: UIApplication,","                 continue userActivity: NSUserActivity,","                 restorationHandler: @escaping ([UIUserActivityRestoring]?) -> Void) -> Bool","{","","    \/\/ Get URL components from the incoming user activity.","    guard userActivity.activityType == NSUserActivityTypeBrowsingWeb,","        let incomingURL = userActivity.webpageURL else {","        return false","    }","","    if userActivity.userInfo?[\"referrer\"] as? String == \"Appcues\" {","        \/\/ This userActivity was trigged from the Appcues iOS SDK.","    }","","    \/\/ TODO: Parse the `incomingURL` here and return true if the link has been handled, false otherwise.","}"],"type":"codeListing"},{"anchor":"Implementing-a-Domain-Allow-List","text":"Implementing a Domain Allow List","type":"heading","level":2},{"type":"paragraph","inlineContent":[{"text":"You may define a custom key, ","type":"text"},{"type":"codeVoice","code":"AppcuesUniversalLinkHostAllowList"},{"text":", in your ","type":"text"},{"inlineContent":[{"type":"text","text":"Info.plist"}],"type":"emphasis"},{"text":" file with an array of (string) host values to control which URLs are passed to ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate.application(_:continue:restorationHandler:)"},{"text":". A URL whose host matches any of the provided host values will be treated as a potential universal link.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An empty array will prevent all links from be treated as universal links and is functionally the same as calling ","type":"text"},{"isActive":true,"type":"reference","identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config\/enableUniversalLinks(_:)"},{"text":" with a ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" argument.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the ","type":"text"},{"type":"codeVoice","code":"AppcuesUniversalLinkHostAllowList"},{"text":" key is absent from ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":", all ","type":"text"},{"type":"codeVoice","code":"https"},{"text":" links will be treated as potential universal links.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Example ","type":"text"},{"inlineContent":[{"type":"text","text":"Info.plist"}],"type":"emphasis"},{"text":" to only treat links to ","type":"text"},{"type":"codeVoice","code":"appcues.com"},{"text":" as universal links:","type":"text"}]},{"syntax":"plist","code":["<?xml version=\"1.0\" encoding=\"UTF-8\"?>","<!DOCTYPE plist PUBLIC \"-\/\/Apple\/\/DTD PLIST 1.0\/\/EN\" \"http:\/\/www.apple.com\/DTDs\/PropertyList-1.0.dtd\">","<plist version=\"1.0\">","<dict>","    ...","    <key>AppcuesUniversalLinkHostAllowList<\/key>","    <array>","        <string>appcues.com<\/string>","    <\/array>","<\/dict>","<\/plist>"],"type":"codeListing"}]}],"kind":"article","variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/appcueskit\/universallinking"]}],"schemaVersion":{"minor":3,"patch":0,"major":0},"sections":[],"abstract":[{"text":"The Appcues iOS SDK supports universal links as an option for deep linking to screens within your app.","type":"text"}],"references":{"doc://com.appcues.sdk/documentation/Appcue