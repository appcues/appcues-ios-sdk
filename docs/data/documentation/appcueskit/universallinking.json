{"kind":"article","schemaVersion":{"major":0,"minor":3,"patch":0},"identifier":{"interfaceLanguage":"swift","url":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/UniversalLinking"},"metadata":{"modules":[{"name":"AppcuesKit"}],"roleHeading":"Article","role":"article","title":"Configuring Handling of Universal Links"},"sections":[],"hierarchy":{"paths":[["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit"]]},"seeAlsoSections":[{"anchor":"Navigation","title":"Navigation","generated":true,"identifiers":["doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/HandlingNavigation","doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/AppcuesNavigationDelegate"]}],"primaryContentSections":[{"kind":"content","content":[{"anchor":"Overview","type":"heading","text":"Overview","level":2},{"inlineContent":[{"type":"text","text":"You must implement "},{"code":"UIApplicationDelegate.application(_:continue:restorationHandler:)","type":"codeVoice"},{"type":"text","text":" to handle your universal links. By default, the Appcues iOS SDK will call this method for every "},{"code":"https","type":"codeVoice"},{"type":"text","text":" link it tries to open to allow your app a chance to handle it internally instead of opening the link in a browser. Optionally, you may provide an allow list of URL hosts—refer to the Domain Allow List section below."}],"type":"paragraph"},{"content":[{"type":"paragraph","inlineContent":[{"text":"If your app has opted into ","type":"text"},{"identifier":"https:\/\/developer.apple.com\/documentation\/uikit\/app_and_environment\/scenes","type":"reference","isActive":true},{"text":", you still must implement the ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate"},{"text":" method to handle universal links triggered from the Appcues iOS SDK.","type":"text"}]}],"name":"Note","style":"note","type":"aside"},{"level":2,"type":"heading","text":"Implementing the NSUserActivity Handler","anchor":"Implementing-the-NSUserActivity-Handler"},{"type":"paragraph","inlineContent":[{"text":"Your implementation of ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate.application(_:continue:restorationHandler:)"},{"text":" must return ","type":"text"},{"type":"codeVoice","code":"true"},{"text":" if you’ve successfully handled the link and ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" otherwise.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If needed, you can identify links coming from the Appcues iOS SDK by a ","type":"text"},{"type":"codeVoice","code":"referrer"},{"text":" property in the ","type":"text"},{"type":"codeVoice","code":"NSUserActivity.userInfo"},{"text":" dictionary.","type":"text"}]},{"syntax":"swift","code":["\/\/ AppDelegate.swift","","func application(_ application: UIApplication,","                 continue userActivity: NSUserActivity,","                 restorationHandler: @escaping ([UIUserActivityRestoring]?) -> Void) -> Bool","{","","    \/\/ Get URL components from the incoming user activity.","    guard userActivity.activityType == NSUserActivityTypeBrowsingWeb,","        let incomingURL = userActivity.webpageURL else {","        return false","    }","","    if userActivity.userInfo?[\"referrer\"] as? String == \"Appcues\" {","        \/\/ This userActivity was trigged from the Appcues iOS SDK.","    }","","    \/\/ TODO: Parse the `incomingURL` here and return true if the link has been handled, false otherwise.","}"],"type":"codeListing"},{"level":2,"type":"heading","text":"Implementing a Domain Allow List","anchor":"Implementing-a-Domain-Allow-List"},{"type":"paragraph","inlineContent":[{"text":"You may define a custom key, ","type":"text"},{"type":"codeVoice","code":"AppcuesUniversalLinkHostAllowList"},{"text":", in your ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Info.plist","type":"text"}]},{"text":" file with an array of (string) host values to control which URLs are passed to ","type":"text"},{"type":"codeVoice","code":"UIApplicationDelegate.application(_:continue:restorationHandler:)"},{"text":". A URL whose host matches any of the provided host values will be treated as a potential universal link.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"An empty array will prevent all links from be treated as universal links and is functionally the same as calling ","type":"text"},{"identifier":"doc:\/\/com.appcues.sdk\/documentation\/AppcuesKit\/Appcues\/Config\/enableUniversalLinks(_:)","type":"reference","isActive":true},{"text":" with a ","type":"text"},{"type":"codeVoice","code":"false"},{"text":" argument.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"If the ","type":"text"},{"type":"codeVoice","code":"AppcuesUniversalLinkHostAllowList"},{"text":" key is absent from ","type":"text"},{"type":"codeVoice","code":"Info.plist"},{"text":", all ","type":"text"},{"type":"codeVoice","code":"https"},{"text":" links will be treated as potential universal links.","type":"text"}]},{"type":"paragraph","inlineContent":[{"text":"Example ","type":"text"},{"type":"emphasis","inlineContent":[{"text":"Info.plist","type":"text"}]},{"text":" to only treat links to ","type":"text"},{"type":"codeVoice","code":"appcues.com"},{"text":" as universal links:","type":"text"}]},{"syntax":"plist","code":["<?xml version=\"1.0\" encoding=\"UTF-8\"?>","<!DOCTYPE plist PUBLIC \"-\/\/Apple\/\/DTD PLIST 1.0\/\/EN\" \"http:\/\/www.apple.com\/DTDs\/PropertyList-1.0.dtd\">","<plist version=\"1.0\">","<dict>","    ...","    <key>AppcuesUniversalLinkHostAllowList<\/key>","    <array>","        <string>appcues.com<\/string>","    <\/array>","<\/dict>","<\/plist>"],"type":"codeListing"}]}],"variants":[{"traits":[{"interfaceLanguage":"swift"}],"paths":["\/documentation\/appcueskit\/universallinking"]}],"abstract":[{"type":"text","text":"The Appcues iOS SDK supports universal links as an option for deep linking to screens within your app."}],"references":{"doc://com.appcues.sdk/documentation/Appcue